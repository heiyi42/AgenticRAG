# Runtime
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Optional alternate providers / tracing
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=
LANGCHAIN_TRACING=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=AgenticRAG
TAVILY_API_KEY=

# Optional Neo4j graph tooling
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=
NEO4J_DATABASE=
NEO4J_OVERWRITE=false
AURA_INSTANCEID=
AURA_INSTANCENAME=

# Core RAG defaults
RAG_WORKING_DIR=./storage/operating_systems
RAG_MAX_RETRY=1
RAG_DEBUG=0
LIGHTRAG_EMBED_MODEL=text-embedding-3-large
LIGHTRAG_EMBED_DIM=3072
LIGHTRAG_EMBED_MAX_TOKEN_SIZE=8192

# Web app
WEB_HOST=127.0.0.1
WEB_PORT=7860
WEB_DEBUG=0
WEB_STORAGE_ROOT=./storage
WEB_CHAT_STORE_PATH=./data/web_chats.json
WEB_ENABLE_SUMMARY_MEMORY=1
WEB_ENABLE_CODE_ANALYSIS=1
WEB_CODE_ANALYSIS_TIMEOUT_S=15
WEB_CODE_ANALYSIS_MAX_CHARS=12000
WEB_CODE_ANALYSIS_COMPILER=
WEB_ENABLE_CODE_EXECUTION=1
WEB_CODE_EXECUTION_TIMEOUT_S=2
WEB_CODE_EXECUTION_MAX_CHARS=4000
WEB_CODE_EXECUTION_MAX_OUTPUT_CHARS=1200
WEB_ENABLE_PROBLEM_TUTORING=1
WEB_PROBLEM_TUTORING_PREP_TIMEOUT_S=18
QUESTION_BANK_EMBED_ENABLED=1
QUESTION_BANK_EMBED_INDEX_PATH=./data/tutoring_question_bank/questions.embedding_index.json
QUESTION_BANK_EMBED_MODEL=text-embedding-3-small
QUESTION_BANK_EMBED_TOP_K=8
QUESTION_BANK_EMBED_BATCH_SIZE=32
QUESTION_BANK_EMBED_TRIGGER_SCORE=185

# Routing / retrieval
WEB_ENABLE_RETRIEVAL_GATE=1
WEB_RETRIEVAL_GATE_TIMEOUT_S=8
WEB_DIRECT_ANSWER_TIMEOUT_S=20
WEB_AUTO_TIMEOUT_S=180

# Instant / deep defaults
INSTANT_TOP_K=20
INSTANT_CHUNK_TOP_K=10
DEEP_QUERY_TIMEOUT_S=120
